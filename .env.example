# ─────────────────────────────────────────────
# Brand Monitor — Environment Variables
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/brand_monitor"

# Next.js / Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-min-32-chars-change-this"  # openssl rand -base64 32

# Admin account (used by seed)
ADMIN_EMAIL="admin@brandmonitor.com"
ADMIN_PASSWORD="changeme123"

# ─── Telegram (optional but recommended) ───
TELEGRAM_BOT_TOKEN=""     # From @BotFather
TELEGRAM_CHAT_ID=""       # Your group/channel ID

# ─── AI Analysis (at least one required for smart classification) ───
OPENAI_API_KEY=""         # sk-...
GEMINI_API_KEY=""         # AIza...
AI_PROVIDER="openai"      # openai | gemini

# ─── Crawler Settings ───
CRAWL_INTERVAL_MINUTES="60"
SEARCH_INTERVAL_HOURS="6"
AI_CONFIDENCE_THRESHOLD="0.6"
IMPORTANCE_THRESHOLD="0.5"
DAILY_DIGEST_HOUR="8"
MAX_RETRIES="3"
NOTIFICATION_TYPES="NEW_PRODUCT,NEW_COLLECTION,LIMITED_DROP,RESTOCK"
